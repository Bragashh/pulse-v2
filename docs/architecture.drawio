<mxfile host="app.diagrams.net">
  <diagram name="Pulse v2 Architecture" id="pulse-v2">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Pulse v2 — Self-Service DevOps Platform" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1F2933;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="700" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== USER LAYER ===== -->
        <mxCell id="lane_user" value="User Layer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#1E3A8A;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="900" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="user" value="Developer&#xa;(uses dashboard)" style="shape=actor;html=1;fillColor=#FEF3C7;strokeColor=#92400E;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="115" width="50" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="dashboard" value="Pulse Dashboard&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 10px&quot;&gt;HTML / JavaScript&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1E40AF;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="120" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== PULSE PLATFORM ===== -->
        <mxCell id="lane_platform" value="Pulse Platform (development VM / future EC2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#374151;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="900" height="320" as="geometry"/>
        </mxCell>

        <mxCell id="backend" value="Pulse Backend&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 10px&quot;&gt;Flask · REST API&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#15803D;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="280" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="sqlite" value="SQLite&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 10px&quot;&gt;deployed services&#xa;deployment audit log&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#FFFFFF;strokeColor=#15803D;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="380" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- Monitoring stack -->
        <mxCell id="prometheus" value="Prometheus&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 10px&quot;&gt;metrics scrape&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#9A3412;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="280" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="grafana" value="Grafana&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 10px&quot;&gt;dashboards&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FED7AA;strokeColor=#9A3412;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="510" y="280" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="loki" value="Loki&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 10px&quot;&gt;log storage&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#991B1B;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="365" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="promtail" value="Promtail&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 10px&quot;&gt;tails Docker logs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#991B1B;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="510" y="365" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="monitoring_label" value="Observability Stack&#xa;(Docker Compose)" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="340" y="430" width="310" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="monitoring_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9A3412;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="265" width="340" height="200" as="geometry"/>
        </mxCell>

        <!-- ===== KUBERNETES LAYER ===== -->
        <mxCell id="lane_k8s" value="Kubernetes (k3s cluster)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#166534;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="900" height="280" as="geometry"/>
        </mxCell>

        <!-- pulse-deployed namespace -->
        <mxCell id="ns_pulse" value="namespace: pulse-deployed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#166534;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="80" y="610" width="380" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="pod_staging" value="user-svc&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 9px&quot;&gt;Deployment + Service&#xa;staging · 2 replicas&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#92400E;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="650" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="pod_prod" value="user-svc-prod&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 9px&quot;&gt;Deployment + Service&#xa;production · 2 replicas&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#1E40AF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="650" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="ns_pulse_label" value="services deployed via the Pulse form&#xa;(Pulse calls k8s API to create these)" style="text;html=1;align=center;verticalAlign=middle;fontSize=9;fontStyle=2;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="100" y="720" width="340" height="30" as="geometry"/>
        </mxCell>

        <!-- url-shortener namespace -->
        <mxCell id="ns_url" value="namespace: url-shortener" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#166534;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="490" y="610" width="380" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="redis" value="Redis&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 9px&quot;&gt;ClusterIP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#991B1B;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="510" y="650" width="140" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="shortener" value="URL Shortener&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 9px&quot;&gt;Flask · NodePort&#xa;2 replicas&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDD6FE;strokeColor=#5B21B6;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="650" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="ns_url_label" value="example service deployed manually&#xa;(provisioned in Step 9)" style="text;html=1;align=center;verticalAlign=middle;fontSize=9;fontStyle=2;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="510" y="720" width="340" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== EXTERNAL ===== -->
        <mxCell id="external_box" value="External Integrations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAE8FF;strokeColor=#86198F;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="980" y="80" width="320" height="460" as="geometry"/>
        </mxCell>

        <mxCell id="github" value="GitHub API&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 10px&quot;&gt;DORA metrics:&#xa;commits, workflow runs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#86198F;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="140" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="external_svcs" value="Monitored Services&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 10px&quot;&gt;Google · GitHub · Gitea&#xa;and user-added URLs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#86198F;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="240" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="github_actions" value="GitHub Actions&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 10px&quot;&gt;CI: pytest, Docker build&#xa;Push to ECR (disabled in v2)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#86198F;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="340" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="terraform" value="Terraform + Ansible&#xa;&lt;font color=&quot;#475569&quot; style=&quot;font-size: 10px&quot;&gt;infrastructure provisioning&#xa;(modular, AWS-ready)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#86198F;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="440" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- ===== ARROWS / CONNECTIONS ===== -->

        <!-- User → Dashboard -->
        <mxCell id="arrow_user_dash" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;startSize=8;endSize=8;strokeColor=#1E40AF;" edge="1" parent="1" source="user" target="dashboard">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Dashboard → Backend (REST API) -->
        <mxCell id="arrow_dash_backend" value="REST API" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;startSize=8;endSize=8;strokeColor=#1E40AF;fontSize=10;" edge="1" parent="1" source="dashboard" target="backend">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Backend ↔ SQLite -->
        <mxCell id="arrow_backend_sqlite" value="reads/writes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.3;exitY=1;exitDx=0;exitDy=0;entryX=0.3;entryY=0;entryDx=0;entryDy=0;endArrow=classic;startSize=8;endSize=8;startArrow=classic;strokeColor=#15803D;fontSize=10;" edge="1" parent="1" source="backend" target="sqlite">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Prometheus → Backend (scrape) -->
        <mxCell id="arrow_prom_backend" value="scrape /prometheus-metrics" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;startSize=8;endSize=8;strokeColor=#9A3412;fontSize=9;" edge="1" parent="1" source="prometheus" target="backend">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Promtail → Loki -->
        <mxCell id="arrow_promtail_loki" value="ship logs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;startSize=8;endSize=8;strokeColor=#991B1B;fontSize=9;" edge="1" parent="1" source="promtail" target="loki">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Grafana → Prometheus -->
        <mxCell id="arrow_grafana_prom" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;startSize=8;endSize=8;strokeColor=#9A3412;fontSize=9;" edge="1" parent="1" source="grafana" target="prometheus">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Grafana → Loki -->
        <mxCell id="arrow_grafana_loki" value="queries" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.3;entryDx=0;entryDy=0;endArrow=classic;startSize=8;endSize=8;strokeColor=#991B1B;fontSize=9;" edge="1" parent="1" source="grafana" target="loki">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Backend → Kubernetes (deploy) -->
        <mxCell id="arrow_backend_k8s" value="Kubernetes API: deploy / promote / rollback" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.3;entryY=0;entryDx=0;entryDy=0;endArrow=classic;startSize=8;endSize=8;strokeColor=#15803D;fontSize=10;fontStyle=1;" edge="1" parent="1" source="backend" target="ns_pulse">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Backend → GitHub -->
        <mxCell id="arrow_backend_github" value="DORA queries" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;startSize=8;endSize=8;strokeColor=#86198F;fontSize=10;" edge="1" parent="1" source="backend" target="github">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Backend → external services -->
        <mxCell id="arrow_backend_ext" value="uptime checks" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;startSize=8;endSize=8;strokeColor=#86198F;fontSize=10;" edge="1" parent="1" source="backend" target="external_svcs">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Redis ↔ Shortener (intra-namespace) -->
        <mxCell id="arrow_redis_shortener" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;startSize=8;endSize=8;startArrow=classic;strokeColor=#5B21B6;" edge="1" parent="1" source="redis" target="shortener">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>